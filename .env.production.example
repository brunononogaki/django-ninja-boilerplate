# DATABASE
DATABASE_HOST=boilerplate_database
DATABASE_PORT=5432
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=postgres

# GENERAL CONFIG
BACKEND_FQDN=myapi.brunononogaki.com
FRONTEND_FQDN=react.brunononogaki.com

# FRONTEND CONFIG
NEXT_PUBLIC_API_URL=https://myapi.brunononogaki.com

# BACKEND CONFIG
DEBUG=False
SECRET_KEY='mysecretkey-pro'
ALLOWED_HOSTS=localhost,127.0.0.1,.brunononogaki.com
CSRF_TRUSTED_ORIGINS=https://myapi.brunononogaki.com
CORS_ALLOWED_ORIGINS=https://react.brunononogaki.com

# COOKIES — necessário para que os cookies JWT funcionem entre subdomínios (myapi. e react.)
COOKIE_DOMAIN=.brunononogaki.com
COOKIE_SECURE=True


# DJANGO CONFIG
DJANGO_ADMIN_USER = 'admin'
DJANGO_ADMIN_EMAIL = 'admin@admin.com'
DJANGO_ADMIN_PASSWORD = 'devpassword'

# EMAIL CONFIG
GMAIL_EMAIL=email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

